{
  "rewrites": [
    {
      "source": "/",
      "destination": "/site1.html"
    },
    {
      "source": "/site1",
      "destination": "/site1.html"
    },
    {
      "source": "/site2",
      "destination": "/site2.html"
    },
    {
      "source": "/site3",
      "destination": "/site3.html"
    },
    {
      "source": "/thanks",
      "destination": "/thanks.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
